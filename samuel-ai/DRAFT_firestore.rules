rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable functions
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == userId &&
               data.email is string && data.email.size() <= 256 &&
               data.displayName is string && data.displayName.size() <= 128 &&
               data.role in ['admin', 'member'];
      }

      allow get: if isSignedIn();
      allow list: if false; // Profiles are private or fetched by UID
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'member';
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    // Projects
    match /projects/{projectId} {
      function isValidProject(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 128 &&
               data.ownerId == request.auth.uid &&
               data.status in ['active', 'completed', 'archived'] &&
               isValidId(projectId);
      }

      allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.members);
      allow create: if isVerified() && isValidProject(incoming());
      allow update: if isVerified() && isOwner(existing().ownerId) && isValidProject(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasAny(['name', 'description', 'status', 'updatedAt']);
      allow delete: if isVerified() && isOwner(existing().ownerId);

      // Insights subcollection
      match /insights/{insightId} {
        allow read: if isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
        // Insights are system-generated (via Cloud Functions or server usually), 
        // but here we allow user to create them for demo purposes if they own the project
        allow create: if isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      }
    }
  }
}
