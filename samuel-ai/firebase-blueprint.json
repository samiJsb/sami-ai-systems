{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "member"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "A business project or task container",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "archived"] },
        "ownerId": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status", "ownerId"]
    },
    "Insight": {
      "title": "AI Insight",
      "description": "AI-generated insights from project data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["risk", "opportunity", "summary"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and settings"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Main projects collection"
    },
    "/projects/{projectId}/insights/{insightId}": {
      "schema": "Insight",
      "description": "AI insights for specific projects"
    }
  }
}
